{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom", "dom.iterable"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    // Flags from @tsconfig/strictest we deliberately turn OFF:

    "noUncheckedIndexedAccess": true,

    // exactOptionalPropertyTypes — interacts awkwardly with JSON and
    // external data; the distinction between `x?: T` and `x: T | undefined`
    // rarely matters in practice here.
    "exactOptionalPropertyTypes": false,

    // noPropertyAccessFromIndexSignature — enabled now that TS migration is
    // complete.  Some config-bag patterns may need bracket access.
    "noPropertyAccessFromIndexSignature": true
  },
  "include": ["sources", "scripts", "vite", "tests"]
}
